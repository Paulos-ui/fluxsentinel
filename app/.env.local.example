# ─── Solana Network ──────────────────────────────────────────────────────────
# For local development:
NEXT_PUBLIC_RPC_URL=http://localhost:8899
NEXT_PUBLIC_WS_URL=ws://localhost:8900

# For devnet:
# NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
# NEXT_PUBLIC_WS_URL=wss://api.devnet.solana.com

# For Helius devnet (recommended — higher rate limits):
# NEXT_PUBLIC_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
# NEXT_PUBLIC_WS_URL=wss://devnet.helius-rpc.com/?api-key=YOUR_KEY

NEXT_PUBLIC_NETWORK=localnet
# Options: localnet | devnet | mainnet-beta

# ─── Program IDs ─────────────────────────────────────────────────────────────
# Replace with actual deployed IDs after running: anchor deploy
NEXT_PUBLIC_ORACLE_PROGRAM_ID=FSRsk1111111111111111111111111111111111111111
NEXT_PUBLIC_BREAKER_PROGRAM_ID=FSCrk1111111111111111111111111111111111111111
NEXT_PUBLIC_VAULT_PROGRAM_ID=FSVlt1111111111111111111111111111111111111111

# ─── Mock Engine (for local dev) ─────────────────────────────────────────────
# Path to the keypair used as oracle authority (default: Solana CLI wallet)
ORACLE_AUTHORITY_KEY_PATH=~/.config/solana/id.json
ENGINE_INTERVAL_MS=30000

# ─── Vercel deployment ────────────────────────────────────────────────────────
# When deploying to Vercel, set NEXT_PUBLIC_RPC_URL to a devnet/mainnet endpoint
# NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
