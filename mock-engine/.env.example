# Mock Risk Engine Environment
# Copy to .env and fill in before running

# Solana RPC (localnet default)
NEXT_PUBLIC_RPC_URL=http://localhost:8899

# Program IDs (filled automatically by deploy.sh)
NEXT_PUBLIC_ORACLE_PROGRAM_ID=FSRsk1111111111111111111111111111111111111111

# Path to the oracle authority keypair (default: Solana CLI wallet)
ORACLE_AUTHORITY_KEY_PATH=~/.config/solana/id.json

# How often to push score updates (ms). Must be << 300000 (5 min staleness)
ENGINE_INTERVAL_MS=30000

# Logging
LOG_LEVEL=info
